#!/usr/bin/env bash

# Check if global hooks are disabled for this specific repository (e.g., your dotfiles)
if [ "$(git config --local --get hooks.skipGlobal)" != "true" ]; then
  echo "🔍 Running global pre-commit checks..."

  # 1. Check Go formatting (ONLY on staged .go files)
  if command -v gofmt &> /dev/null; then
    # Get a list of staged .go files (Added, Copied, Modified)
    staged_go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
    
    if [ -n "$staged_go_files" ]; then
      unformatted=$(gofmt -l $staged_go_files)
      if [ -n "$unformatted" ]; then
        echo "🚨 ABORT: The following staged files are not formatted:"
        echo "$unformatted"
        echo "Run 'gofmt -w <file>' and try again."
        exit 1
      fi
    else
      echo "⏭️ Skipping 'gofmt' (no .go files staged)."
    fi
  fi

  # 2. Check go vet (only if go.mod exists)
  if [ -f "go.mod" ] && command -v go &> /dev/null; then
    if ! go vet ./...; then
      echo "🚨 ABORT: 'go vet' found issues."
      exit 1
    fi
  else
    echo "⏭️ Skipping 'go vet' (no go.mod found)."
  fi

  # 3. Check golangci-lint (only if a config file exists)
  if command -v golangci-lint &> /dev/null; then
    has_golangci_config=false
    for f in .golangci.yml .golangci.yaml .golangci.toml .golangci.json; do
      if [ -f "$f" ]; then
        has_golangci_config=true
        break
      fi
    done

    if [ "$has_golangci_config" = true ]; then
      if ! golangci-lint run; then
        echo "🚨 ABORT: 'golangci-lint' found issues."
        exit 1
      fi
    else
      echo "⏭️ Skipping 'golangci-lint' (no config file found)."
    fi
  fi

  echo "✅ All global pre-commit checks passed!"
else
  echo "⏭️ Skipping global pre-commit checks for this repository."
fi

# =========================================================
# DISPATCHER FOR LOCAL REPO HOOKS
# =========================================================
HOOK_NAME=$(basename "$0")
LOCAL_HOOK_CONFIG=$(git config --local --get hooks.localPath || true)

if [ -n "$LOCAL_HOOK_CONFIG" ]; then
  if [ -d "$LOCAL_HOOK_CONFIG" ]; then
    LOCAL_HOOK="$LOCAL_HOOK_CONFIG/$HOOK_NAME"
    if [ -x "$LOCAL_HOOK" ] && [ ! -d "$LOCAL_HOOK" ]; then
      echo "🔗 Running local repository hook ($LOCAL_HOOK)..."
      exec "$LOCAL_HOOK" "$@"
    fi
  elif [ -f "$LOCAL_HOOK_CONFIG" ] && [ -x "$LOCAL_HOOK_CONFIG" ]; then
    echo "🔗 Running local repository hook file ($LOCAL_HOOK_CONFIG)..."
    exec "$LOCAL_HOOK_CONFIG" "$@"
  fi
fi

exit 0