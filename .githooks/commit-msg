#!/usr/bin/env bash

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Check if global hooks are disabled for this specific repository
if [ "$(git config --local --get hooks.skipGlobal)" != "true" ]; then
  # Skip checks for merge commits
  if [[ ! $commit_msg =~ ^Merge ]]; then
    regex="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9_-]+\))?!?: .+"

    if [[ ! $commit_msg =~ $regex ]]; then
      echo ""
      echo "🚨 ABORT: Your commit message does not meet the standard!"
      echo -e "Your input: \033[31m$commit_msg\033[0m"
      echo "Expected format: <type>(<scope>): <subject>"
      echo "Allowed Types: feat, fix, chore, refactor, docs, test, perf"
      exit 1
    fi
  fi
fi

# =========================================================
# DISPATCHER FOR LOCAL REPO HOOKS
# =========================================================
HOOK_NAME=$(basename "$0")
LOCAL_HOOK_CONFIG=$(git config --local --get hooks.localPath || true)

if [ -n "$LOCAL_HOOK_CONFIG" ]; then
  if [ -d "$LOCAL_HOOK_CONFIG" ]; then
    LOCAL_HOOK="$LOCAL_HOOK_CONFIG/$HOOK_NAME"
    if [ -x "$LOCAL_HOOK" ] && [ ! -d "$LOCAL_HOOK" ]; then
      echo "🔗 Running local repository hook ($LOCAL_HOOK)..."
      exec "$LOCAL_HOOK" "$@"
    fi
  elif [ -f "$LOCAL_HOOK_CONFIG" ] && [ -x "$LOCAL_HOOK_CONFIG" ]; then
    echo "🔗 Running local repository hook file ($LOCAL_HOOK_CONFIG)..."
    exec "$LOCAL_HOOK_CONFIG" "$@"
  fi
fi

exit 0